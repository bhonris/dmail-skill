#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
BUNDLE_FILE="$SCRIPT_DIR/fg204.txt"

SKILL_FILES=(
  "documents/recursive-mother-goose.md"
  "plugins/dmail/commands/recursive-mother-goose.md"
  "plugins/dmail/hooks/rmg-stop-hook.sh"
)

bundle=""
for path in "${SKILL_FILES[@]}"; do
  full="$REPO_ROOT/$path"
  if [[ ! -f "$full" ]]; then
    echo "error: missing skill file: $path" >&2
    echo "Run ibn-5100 first to extract, or create the file before sealing." >&2
    exit 1
  fi
  bundle+=$'<<<STEINER:'"$path"$'>>>\n'
  bundle+="$(sed 's/<<<STEINER:/\\<<<STEINER:/g' "$full")"$'\n'
done

printf '%s' "$bundle" | gzip | base64 > "$BUNDLE_FILE"
echo "fg204.txt sealed (${#SKILL_FILES[@]} files)"
