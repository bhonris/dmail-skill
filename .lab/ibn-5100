#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
BUNDLE_FILE="$SCRIPT_DIR/fg204.txt"

if [[ ! -f "$BUNDLE_FILE" ]]; then
  echo "error: fg204.txt not found in $(dirname "$BUNDLE_FILE")" >&2
  exit 1
fi

first_run=false
[[ ! -f "$REPO_ROOT/documents/recursive-mother-goose.md" ]] && first_run=true

bundle=$(base64 -d "$BUNDLE_FILE" | gunzip)

current_file=""
current_content=""

flush() {
  if [[ -n "$current_file" ]]; then
    dest="$REPO_ROOT/$current_file"
    mkdir -p "$(dirname "$dest")"
    printf '%s' "$current_content" | sed 's/\\<<<STEINER:/<<<STEINER:/g' > "$dest"
    if [[ "$current_file" == *.sh ]]; then
      chmod +x "$dest"
    fi
    echo "  -> $current_file"
    current_file=""
    current_content=""
  fi
}

while IFS= read -r line; do
  if [[ "$line" =~ ^\<\<\<STEINER:(.+)\>\>\>$ ]]; then
    flush
    current_file="${BASH_REMATCH[1]}"
  else
    [[ -n "$current_file" ]] && current_content+="$line"$'\n'
  fi
done <<< "$bundle"

flush

if [[ "$first_run" == true ]]; then
  echo ""
  echo "El Psy Kongroo."
  echo ""
  echo "You found it. This is Recursive Mother Goose — a self-improvement loop for the"
  echo "D-Mail skill, hidden here as an easter egg for whoever dug deep enough to find it."
  echo ""
  echo "Start with documents/recursive-mother-goose.md."
  echo ""
  echo "Remember to register the RMG stop hook:"
  echo "  Run /update-config and add plugins/dmail/hooks/rmg-stop-hook.sh as a Stop hook."
else
  echo ""
  echo "Done. Remember to register the RMG stop hook if this is a fresh extract:"
  echo "  Run /update-config and add plugins/dmail/hooks/rmg-stop-hook.sh as a Stop hook."
fi
